///|
let version = "0.1.0"

///|
fn print_help() -> Unit {
  println("purus v" + version + " - A language that compiles to JavaScript")
  println("")
  println("Usage:")
  println("  purus build <file>                   Compile to JavaScript")
  println("    .purus  -> .js")
  println("    .cpurus -> .cjs (CommonJS)")
  println("    .mpurus -> .mjs (ES Module)")
  println("  purus build --no-header <file>        Compile without header comment")
  println("  purus check <file.purus>               Syntax check only")
  println("  purus new <name>                       Create a new project")
  println("  purus init                             Initialize project in current directory")
  println("  purus version                          Show version")
  println("  purus help                             Show this help")
  println("")
  println("Aliases: compile = build, create = new")
}

///|
fn print_version() -> Unit {
  println("purus v" + version)
}

///|
fn cmd_build(args : Array[String]) -> Unit {
  let mut file = ""
  let mut no_header = false
  let mut to_stdout = false
  let mut i = 0
  while i < args.length() {
    if args[i] == "--no-header" {
      no_header = true
    } else if args[i] == "--stdout" {
      to_stdout = true
    } else {
      file = args[i]
    }
    i += 1
  }
  if file == "" {
    println("Error: no input file specified")
    println("Usage: purus build <file.purus|.cpurus|.mpurus>")
    return
  }
  // Read source file
  let src = try {
    @fs.read_file_to_string(file)
  } catch {
    @fs.IOError(msg) => {
      println("Error: cannot read file '" + file + "': " + msg)
      return
    }
  }
  // Compile
  let tokens = @core.Lexer::new(src).tokenize()
  // Extract shebang if present
  let mut shebang = ""
  let mut tok_start = 0
  if tokens.length() > 0 {
    match tokens[0].kind {
      @core.Shebang(s) => {
        shebang = s
        tok_start = 1
        // Also skip the Newline token after shebang
        if tok_start < tokens.length() {
          match tokens[tok_start].kind {
            @core.Newline => tok_start = tok_start + 1
            _ => ()
          }
        }
      }
      _ => ()
    }
  }
  // Filter tokens for parser (skip shebang + its newline)
  let filtered : Array[@core.Token] = []
  let mut fi = tok_start
  while fi < tokens.length() {
    filtered.push(tokens[fi])
    fi += 1
  }
  let stmts = @core.Parser::new(filtered).parse()
  let header = if no_header {
    ""
  } else {
    "// Generated by Purus " + version
  }
  let js = @core.JsCodegen::new().generate(stmts, header~, shebang~)
  if to_stdout {
    println(js)
    return
  }
  // Write output to file
  let base_and_ext = if file.has_suffix(".cpurus") {
    let chars = file.to_array()
    let buf = StringBuilder::new()
    let mut i = 0
    while i < chars.length() - 7 {
      buf.write_char(chars[i])
      i += 1
    }
    (buf.to_string(), ".cjs")
  } else if file.has_suffix(".mpurus") {
    let chars = file.to_array()
    let buf = StringBuilder::new()
    let mut i = 0
    while i < chars.length() - 7 {
      buf.write_char(chars[i])
      i += 1
    }
    (buf.to_string(), ".mjs")
  } else if file.has_suffix(".purus") {
    let chars = file.to_array()
    let buf = StringBuilder::new()
    let mut i = 0
    while i < chars.length() - 6 {
      buf.write_char(chars[i])
      i += 1
    }
    (buf.to_string(), ".js")
  } else {
    (file, ".js")
  }
  let out_file = base_and_ext.0 + base_and_ext.1
  try {
    @fs.write_string_to_file(out_file, js)
  } catch {
    @fs.IOError(msg) => {
      println("Error: cannot write file '" + out_file + "': " + msg)
      return
    }
  }
  println("Compiled " + file + " -> " + out_file)
}

///|
fn cmd_check(file : String) -> Unit {
  if file == "" {
    println("Error: no input file specified")
    println("Usage: purus check <file.purus|.cpurus|.mpurus>")
    return
  }
  let src = try {
    @fs.read_file_to_string(file)
  } catch {
    @fs.IOError(msg) => {
      println("Error: cannot read file '" + file + "': " + msg)
      return
    }
  }
  let tokens = @core.Lexer::new(src).tokenize()
  let _stmts = @core.Parser::new(tokens).parse()
  println("OK: " + file)
}

///|
fn cmd_new(name : String) -> Unit {
  if name == "" {
    println("Error: project name required")
    println("Usage: purus new <name>")
    return
  }
  // Create project directory
  if @fs.path_exists(name) {
    println("Error: directory '" + name + "' already exists")
    return
  }
  try {
    @fs.create_dir(name)
  } catch {
    @fs.IOError(msg) => {
      println("Error: cannot create directory: " + msg)
      return
    }
  }
  try {
    @fs.create_dir(name + "/src")
  } catch {
    @fs.IOError(msg) => {
      println("Error: cannot create src directory: " + msg)
      return
    }
  }
  // Write purus.json
  let purus_json = "{\n  \"name\": \"" + name + "\",\n  \"version\": \"0.1.0\",\n  \"main\": \"src/main.purus\"\n}\n"
  try {
    @fs.write_string_to_file(name + "/purus.json", purus_json)
  } catch {
    @fs.IOError(msg) => {
      println("Error: " + msg)
      return
    }
  }
  // Write main.purus
  let main_purus =
    #|-- main.purus
    #|
    #|const message be ///Hello, World///
    #|console.log[message]
    #|
  try {
    @fs.write_string_to_file(name + "/src/main.purus", main_purus)
  } catch {
    @fs.IOError(msg) => {
      println("Error: " + msg)
      return
    }
  }
  // Write .gitignore
  let gitignore =
    #|*.js
    #|node_modules/
    #|
  try {
    @fs.write_string_to_file(name + "/.gitignore", gitignore)
  } catch {
    @fs.IOError(msg) => {
      println("Error: " + msg)
      return
    }
  }
  println("Created project '" + name + "'")
  println("  " + name + "/purus.json")
  println("  " + name + "/src/main.purus")
  println("  " + name + "/.gitignore")
}

///|
fn cmd_init() -> Unit {
  if @fs.path_exists("purus.json") {
    println("Error: purus.json already exists in current directory")
    return
  }
  if not(@fs.path_exists("src")) {
    try {
      @fs.create_dir("src")
    } catch {
      @fs.IOError(msg) => {
        println("Error: cannot create src directory: " + msg)
        return
      }
    }
  }
  let purus_json =
    #|{
    #|  "name": "my-project",
    #|  "version": "0.1.0",
    #|  "main": "src/main.purus"
    #|}
    #|
  try {
    @fs.write_string_to_file("purus.json", purus_json)
  } catch {
    @fs.IOError(msg) => {
      println("Error: " + msg)
      return
    }
  }
  if not(@fs.path_exists("src/main.purus")) {
    let main_purus =
      #|-- main.purus
      #|
      #|const message be ///Hello, World///
      #|console.log[message]
      #|
    try {
      @fs.write_string_to_file("src/main.purus", main_purus)
    } catch {
      @fs.IOError(msg) => {
        println("Error: " + msg)
        return
      }
    }
  }
  println("Initialized purus project in current directory")
}

///|
fn main {
  let args = @sys.get_cli_args()
  // args[0] is the program name
  if args.length() < 2 {
    print_help()
    return
  }
  let cmd = args[1]
  match cmd {
    "build" | "compile" => cmd_build(args[2:].to_array())
    "check" => {
      let file = if args.length() > 2 { args[2] } else { "" }
      cmd_check(file)
    }
    "new" | "create" => {
      let name = if args.length() > 2 { args[2] } else { "" }
      cmd_new(name)
    }
    "init" => cmd_init()
    "version" | "--version" | "-v" => print_version()
    "help" | "--help" | "-h" => print_help()
    _ => {
      println("Unknown command: " + cmd)
      print_help()
    }
  }
}
