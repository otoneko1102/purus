{
  "comments": {
    "lineComment": "--",
    "blockComment": ["---", "---"]
  },
  "brackets": [
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "///", "close": "///" }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["///", "///"]
  ],
  "folding": {
    "offSide": true
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(fn|if|elif|else|unless|while|until|for|match|when|try|catch|finally|mod)\\b.*$",
    "decreaseIndentPattern": "^\\s*(elif|else|when|catch|finally)\\b"
  },
  "wordPattern": "[a-zA-Z][a-zA-Z0-9-]*"
}
